# Firebase web app config for browser authentication.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Optional, but usually present in the Firebase config snippet.
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# Optional.
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# Optional override for Google Identity Services if you do not want to use
# the Firebase project's default web client ID.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Control plane base URLs.
# CONTROL_PLANE_URL is used by server components.
# NEXT_PUBLIC_CONTROL_PLANE_URL is used by client-side fetches.
CONTROL_PLANE_URL=http://localhost:4000
NEXT_PUBLIC_CONTROL_PLANE_URL=http://localhost:4000
